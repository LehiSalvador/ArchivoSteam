# ─────────────────────────────────────────────────────────────────────────────
# Archivo STEAM · PLANTILLA de variables de entorno (SIN VALORES)
# Los valores reales viven ÚNICAMENTE en:
#   C:\PROYECTOS_CLAUDE\ARCHIVO_STEAM\04_CREDENCIALES_PRIVADAS\.env.claude.local
# NUNCA escribas valores reales en este archivo (se versiona en Git).
# ─────────────────────────────────────────────────────────────────────────────

# ── Público (enviado al navegador) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase · servidor (NUNCA exponer al navegador) ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Operación / CI (herramientas, no runtime de la app) ──
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
GITHUB_TOKEN=
VERCEL_TOKEN=

# ── YouTube / Google Cloud (solo lectura) ──
YOUTUBE_GOOGLE_CLOUD_PROJECT_ID=
YOUTUBE_API_KEY=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
YOUTUBE_OAUTH_REDIRECT_URI=
YOUTUBE_DATA_API_ENABLED=
YOUTUBE_ANALYTICS_API_ENABLED=
YOUTUBE_REPORTING_API_ENABLED=

# ── ElevenLabs · TTS (futuro) ──
ELEVENLABS_API_KEY=
